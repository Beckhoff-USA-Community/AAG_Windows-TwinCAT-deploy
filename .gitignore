# Exclude all contents of artifacts subdirectories but keep the folder structure
artifacts/TCPKG PACKAGES/*/**
artifacts/POWERSHELL MODULES/*/**
artifacts/TWINCAT BOOT FOLDER/*/**
artifacts/HMI PROJECTS/*/**

# Keep the .gitkeep files to preserve folder structure (flexible folder names)
!artifacts/TCPKG PACKAGES/*/.gitkeep
!artifacts/POWERSHELL MODULES/*/.gitkeep
!artifacts/TWINCAT BOOT FOLDER/*/.gitkeep
!artifacts/HMI PROJECTS/*/.gitkeep

# Keep README file for documentation
!artifacts/README.md

# Keep the HMI config file (must be named exactly this)
!artifacts/HMI PROJECTS/TcHmiSrv.Service.Config.json